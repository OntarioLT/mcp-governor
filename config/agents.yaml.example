# Agent 配置文件
# 定义每个 Agent 的身份和工具权限
# 认证方式：
#   - JWT: Authorization: Bearer <jwt-token>（role 从 JWT token 获取）
#   - API Key: Authorization: ApiKey <api-key>（role 默认为 user）
#
# 注意：role 不在此配置，而是在 JWT/OAuth 认证时由外部系统提供
# Agent 只负责：api_key 认证 + allowed_tools 工具白名单 + rate_limit 限流

agents:
  demo_agent:
    api_key: "<your-api-key>"
    allowed_tools:
      - "erp.query_stock"
      - "erp.query_stock_by_name"
      - "erp.create_stock_entry"
      - "erp.transfer_stock"
      - "erp.health"
      - "crm.get_customer"
      - "crm.get_customer_orders"
      - "crm.create_order"
      - "crm.health"
      - "maps_*"
      - "jp_*"
    rate_limit: 1000/hour

  hr_agent:
    api_key: "<your-api-key>"
    allowed_tools:
      - "hr.*"
    rate_limit: 1000/hour
